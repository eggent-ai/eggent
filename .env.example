# === Eggent Configuration ===

# Provider keys are optional here: users can add model credentials during onboarding/settings.
# Use env vars only when you want server-level fallback credentials.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
OPENROUTER_API_KEY=
TAVILY_API_KEY=

# External integrations API token (optional fallback for /api/external/message)
EXTERNAL_API_TOKEN=replace-with-a-long-random-token

# Optional app auth session secret. If omitted, Eggent generates and stores one in data/settings/auth-secret.
EGGENT_AUTH_SECRET=

# Telegram integration (optional; UI can auto-configure from bot token only)
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=
TELEGRAM_DEFAULT_PROJECT_ID=

# Docker runtime bind settings
APP_BIND_HOST=127.0.0.1
APP_PORT=3000

# Device-to-device data sync (Docker includes a Syncthing sidecar).
# The REST API stays inside the Docker network; override this internal key if desired.
SYNCTHING_API_KEY=replace-with-a-long-random-internal-key
SYNCTHING_DEVICE_NAME=eggent
SYNCTHING_BIND_HOST=0.0.0.0
SYNCTHING_TCP_PORT=22000
SYNCTHING_QUIC_PORT=22000
SYNCTHING_DISCOVERY_PORT=21027
# Native/non-Docker installs can point Eggent at an existing Syncthing daemon:
# SYNCTHING_URL=http://127.0.0.1:8384
# SYNCTHING_DATA_PATH=/absolute/path/to/eggent/data

# Embedded pi SDK config directory.
# Docker default: /app/data/pi-agent. Local setup defaults to existing ~/.pi/agent,
# then falls back to ./data/pi-agent for fresh installs.
# PI_CODING_AGENT_DIR=/Users/you/.pi/agent

# Optional Docker runtime cache/temp paths (inside container).
# Defaults are defined in docker-compose.yml and usually do not need overrides.
# APP_TMP_DIR=/app/data/tmp
# PLAYWRIGHT_BROWSERS_PATH=/app/data/ms-playwright
# NPM_CONFIG_CACHE=/app/data/npm-cache
# XDG_CACHE_HOME=/app/data/.cache

# Optional CLI OAuth credential file overrides (for codex-cli / gemini-cli provider auth checks).
# If unset, Eggent auto-discovers files in common home directories.
# Useful when Eggent runs under a different user than the CLI login user.
# CODEX_AUTH_FILE=/home/node/.codex/auth.json
# GEMINI_OAUTH_CREDS_FILE=/home/node/.gemini/oauth_creds.json
# GEMINI_SETTINGS_FILE=/home/node/.gemini/settings.json

APP_BASE_URL=http://localhost:3000
